---
import PageLayout from "../layouts/PageLayout.astro";
import { getCollection } from "astro:content";
import { render } from "astro:content";
const business = Astro.locals.tenant;

const allFaq = await getCollection("faq");
const faqItems = allFaq.sort((a, b) => a.data.order - b.data.order);

const categories = [
  { id: "general", label: "General" },
  { id: "services", label: "Services" },
  { id: "booking", label: "Booking" },
  { id: "health", label: "Health & Safety" },
  { id: "pricing", label: "Pricing" },
] as const;

// FAQPage JSON-LD structured data
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.data.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.body,
    },
  })),
};
---

<PageLayout
  title="Frequently Asked Questions"
  heading="Frequently Asked Questions"
  subheading="Common questions about our services, booking, and policies."
  centered={true}
  jsonLd={faqJsonLd}
>
  <section class="mx-auto max-w-3xl px-4 pb-20 sm:px-6 lg:px-8">
    {
      categories.map((cat) => {
        const catItems = faqItems.filter(
          (item) => item.data.category === cat.id,
        );
        if (catItems.length === 0) return null;

        return (
          <div class="mb-12">
            <h2 class="mb-5 font-display text-lg font-bold text-dark border-b border-neutral-200 pb-3">
              {cat.label}
            </h2>
            <div class="space-y-3">
              {catItems.map(async (item) => {
                const { Content } = await render(item);
                return (
                  <details class="group rounded-xl border border-neutral-200 bg-neutral-50/50 transition-colors open:bg-white open:shadow-sm">
                    <summary class="flex cursor-pointer select-none items-center justify-between gap-4 px-6 py-5 text-left font-medium text-dark">
                      <span>{item.data.question}</span>
                      <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-neutral-300 text-neutral-400 transition-all group-open:border-primary-200 group-open:bg-primary-50 group-open:text-primary-600">
                        <svg
                          class="h-3.5 w-3.5 transition-transform group-open:rotate-180"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke-width="2.5"
                          stroke="currentColor"
                          aria-hidden="true"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M19.5 8.25l-7.5 7.5-7.5-7.5"
                          />
                        </svg>
                      </span>
                    </summary>
                    <div class="px-6 pb-5 text-sm leading-relaxed text-neutral-600 prose prose-sm">
                      <Content />
                    </div>
                  </details>
                );
              })}
            </div>
          </div>
        );
      })
    }
  </section>

  {/* Still have questions CTA */}
  <section
    class="relative overflow-hidden bg-primary-600 py-16"
    aria-labelledby="faq-cta"
  >
    <div
      class="absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 24px 24px;"
      aria-hidden="true"
    >
    </div>
    <div class="relative mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 id="faq-cta" class="font-display text-2xl font-bold text-white">
        Still have questions?
      </h2>
      <p class="mt-3 text-primary-100">
        We're happy to help. Reach out to us directly and we'll get back to you
        quickly.
      </p>
      <div
        class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center"
      >
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-semibold text-primary-700 shadow-lg transition-all hover:bg-neutral-50 active:scale-[0.97]"
        >
          Contact Us
          <svg
            class="h-3.5 w-3.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2.5"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
          </svg>
        </a>
        <a
          href={`tel:${business.phone.replace(/[^+\d]/g, "")}`}
          class="inline-flex items-center gap-2 text-sm font-semibold text-white/90 transition-colors hover:text-white"
        >
          Call {business.phone}
        </a>
      </div>
    </div>
  </section>
</PageLayout>

---
import PageLayout from "../layouts/PageLayout.astro";
import { getCollection } from "astro:content";
const business = Astro.locals.tenant;

const allServices = await getCollection("services");
const services = allServices.sort((a, b) => a.data.order - b.data.order);

const categories = [
  {
    id: "dogs",
    label: "Dog Grooming",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M7.848 8.25l1.536.887M7.848 8.25a3 3 0 11-5.196-3 3 3 0 015.196 3zm1.536.887a2.165 2.165 0 011.083 1.839c.005.56.01 1.121.02 1.681a.333.333 0 01-.104.262 19.412 19.412 0 01-3.233 2.477 14.902 14.902 0 01-6.65 2.604m12.5-9.863l-1.536.887m1.536-.887a3 3 0 115.196-3 3 3 0 01-5.196 3zm-1.536.887a2.165 2.165 0 00-1.083 1.839 24.08 24.08 0 01-.02 1.681.333.333 0 00.104.262 19.412 19.412 0 003.233 2.477 14.902 14.902 0 006.65 2.604" />`,
  },
  {
    id: "cats",
    label: "Cat Grooming",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z" />`,
  },
  {
    id: "specialty",
    label: "Specialty Add-ons",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />`,
  },
] as const;

// JSON-LD for services
const servicesJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `Services — ${business.name}`,
  itemListElement: services.map((s, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "Service",
      name: s.data.title,
      description: s.data.description,
      provider: {
        "@type": "LocalBusiness",
        name: business.name,
      },
      offers: {
        "@type": "Offer",
        priceCurrency: "USD",
        price: s.data.priceStarting,
        priceSpecification: {
          "@type": "PriceSpecification",
          price: s.data.priceStarting,
          priceCurrency: "USD",
          valueAddedTaxIncluded: false,
        },
      },
    },
  })),
};
---

<PageLayout
  title="Services"
  heading="Our Grooming Services"
  subheading="Professional care for every breed, coat type, and personality. Browse our full menu below."
  jsonLd={servicesJsonLd}
>
  {/* Category sections */}
  {
    categories.map((cat) => {
      const categoryServices = services.filter(
        (s) => s.data.category === cat.id,
      );
      if (categoryServices.length === 0) return null;

      return (
        <section
          class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8"
          aria-labelledby={`cat-${cat.id}`}
        >
          <div class="flex items-center gap-4 border-b border-neutral-200 pb-4">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-50 text-primary-600">
              <svg
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                aria-hidden="true"
                set:html={cat.icon}
              />
            </div>
            <h2
              id={`cat-${cat.id}`}
              class="font-display text-2xl font-bold text-dark"
            >
              {cat.label}
            </h2>
          </div>

          <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {categoryServices.map((service) => (
              <article class="group flex flex-col rounded-2xl border border-neutral-100 bg-neutral-50/50 p-6 transition-all duration-300 hover:border-primary-200 hover:bg-white hover:shadow-lg hover:shadow-primary-600/5">
                <div class="flex items-start justify-between">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-600 text-white">
                    <svg
                      class="h-5 w-5"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke-width="1.5"
                      stroke="currentColor"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"
                      />
                    </svg>
                  </div>
                  <span class="rounded-lg bg-accent-50 px-3 py-1.5 text-sm font-semibold text-accent-700">
                    From ${service.data.priceStarting}
                  </span>
                </div>

                <h3 class="mt-5 text-lg font-semibold text-dark">
                  {service.data.title}
                </h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-neutral-600">
                  {service.data.shortDescription}
                </p>

                <div class="mt-4 flex items-center gap-2 text-xs text-neutral-600">
                  <svg
                    class="h-4 w-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"
                    />
                  </svg>
                  {service.data.duration}
                </div>

                <ul
                  class="mt-4 space-y-2 border-t border-neutral-100 pt-4"
                  role="list"
                >
                  {service.data.includes.map((item: string) => (
                    <li class="flex items-start gap-2 text-sm text-neutral-600">
                      <svg
                        class="mt-0.5 h-4 w-4 shrink-0 text-primary-500"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke-width="2"
                        stroke="currentColor"
                        aria-hidden="true"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M4.5 12.75l6 6 9-13.5"
                        />
                      </svg>
                      {item}
                    </li>
                  ))}
                </ul>

                <a
                  href="/booking"
                  class="mt-6 inline-flex items-center justify-center gap-2 rounded-lg bg-primary-600 px-5 py-2.5 text-sm font-semibold text-white transition-all hover:bg-primary-500 active:scale-[0.97]"
                >
                  Book This Service
                  <svg
                    class="h-3.5 w-3.5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2.5"
                    stroke="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
                    />
                  </svg>
                </a>
              </article>
            ))}
          </div>
        </section>
      );
    })
  }

  {/* Bottom CTA */}
  <section
    class="relative overflow-hidden bg-primary-600 py-16"
    aria-labelledby="services-cta"
  >
    <div
      class="absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 24px 24px;"
      aria-hidden="true"
    >
    </div>
    <div class="relative mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 id="services-cta" class="font-display text-2xl font-bold text-white">
        Not sure which service is right?
      </h2>
      <p class="mt-3 text-primary-100">
        Give us a call and we'll help you choose the perfect grooming package
        for your pet's breed, coat, and needs.
      </p>
      <div
        class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center"
      >
        <a
          href="/booking"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-semibold text-primary-700 shadow-lg transition-all hover:bg-neutral-50 active:scale-[0.97]"
        >
          Book an Appointment
          <svg
            class="h-3.5 w-3.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2.5"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
          </svg>
        </a>
        <a
          href={`tel:${business.phone.replace(/[^+\d]/g, "")}`}
          class="inline-flex items-center gap-2 text-sm font-semibold text-white/90 transition-colors hover:text-white"
        >
          <svg
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
            ></path>
          </svg>
          Call {business.phone}
        </a>
      </div>
    </div>
  </section>
</PageLayout>

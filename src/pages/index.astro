---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getImage } from "astro:assets";
import heroImg from "../assets/images/hero-dog.jpg";

const business = Astro.locals.tenant;

// Two versions: fast-loading placeholder + crisp hi-res for swap-in
const heroLo = await getImage({
  src: heroImg,
  width: 640,
  height: 800,
  format: "webp",
  quality: 60,
});
const heroHi = await getImage({
  src: heroImg,
  width: 1280,
  height: 1600,
  format: "webp",
  quality: 85,
});
---

<BaseLayout>
  {
    /* ═══════════════════════════════════════════════════════
      HERO — Editorial split layout
      ═══════════════════════════════════════════════════════ */
  }
  <section class="relative overflow-hidden bg-neutral-50">
    {/* Decorative accent bar */}
    <div
      class="absolute left-0 top-0 h-full w-1.5 bg-linear-to-b from-primary-400 via-primary-600 to-primary-800 lg:w-2"
      aria-hidden="true"
    >
    </div>

    <div
      class="mx-auto grid max-w-7xl gap-8 px-4 py-20 sm:px-6 lg:grid-cols-2 lg:gap-16 lg:px-8 lg:py-32"
    >
      {/* Text */}
      <div class="flex flex-col justify-center">
        <span
          class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-primary-600"
        >
          <span class="h-px w-8 bg-primary-400" aria-hidden="true"></span>
          Manteca's Trusted Groomers
        </span>

        <h1
          class="mt-6 font-display text-4xl font-bold leading-[1.1] tracking-tight text-dark sm:text-5xl lg:text-[3.5rem]"
        >
          Where every pet <br class="hidden sm:block" />
          <span class="relative inline-block">
            leaves beautiful
            <svg
              class="absolute -bottom-3 left-0 w-full"
              viewBox="0 0 200 12"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M2 8C40 2 80 4 120 6C150 8 180 4 198 2"
                stroke="var(--color-accent-400)"
                stroke-width="3"
                stroke-linecap="round"></path>
            </svg>
          </span>
        </h1>

        <p class="mt-6 max-w-lg text-lg leading-relaxed text-neutral-600">
          {business.tagline}. Expert grooming with gentle hands, premium
          products, and a calm environment your pet will actually enjoy.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a
            href="/booking"
            class="inline-flex items-center justify-center gap-2 rounded-lg bg-primary-600 px-7 py-3.5 text-sm font-semibold text-white shadow-lg shadow-primary-600/25 transition-all hover:bg-primary-500 hover:shadow-xl hover:shadow-primary-500/30 active:scale-[0.97]"
          >
            Book an Appointment
            <svg
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2.5"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
            </svg>
          </a>
          <a
            href="/services"
            class="inline-flex items-center justify-center gap-2 rounded-lg px-7 py-3.5 text-sm font-semibold text-dark transition-colors hover:bg-neutral-100"
          >
            Explore Services
          </a>
        </div>

        {/* Trust markers */}
        <div
          class="mt-10 flex items-center gap-6 border-t border-neutral-200 pt-8"
        >
          <div class="text-center">
            <span class="block font-display text-2xl font-bold text-dark"
              >15+</span
            >
            <span class="mt-1 block text-xs text-neutral-600"
              >Years Experience</span
            >
          </div>
          <div class="h-8 w-px bg-neutral-200" aria-hidden="true"></div>
          <div class="text-center">
            <span class="block font-display text-2xl font-bold text-dark"
              >4,000+</span
            >
            <span class="mt-1 block text-xs text-neutral-600">Happy Pets</span>
          </div>
          <div class="h-8 w-px bg-neutral-200" aria-hidden="true"></div>
          <div class="text-center">
            <span class="block font-display text-2xl font-bold text-dark"
              >4.9</span
            >
            <span class="mt-1 block text-xs text-neutral-600">Star Rating</span>
          </div>
        </div>
      </div>

      {/* Image — editorial composition */}
      <div class="relative hidden lg:block">
        <div
          class="absolute -right-4 -top-4 h-72 w-72 rounded-full bg-primary-100/60"
          aria-hidden="true"
        >
        </div>
        <div
          class="absolute -bottom-6 -left-6 h-48 w-48 rounded-full bg-accent-100/60"
          aria-hidden="true"
        >
        </div>
        <div class="relative aspect-4/5 overflow-hidden rounded-2xl shadow-2xl">
          <img
            id="hero-img"
            src={heroLo.src}
            data-hires={heroHi.src}
            alt="A happy, freshly groomed dog smiling at the camera"
            class="h-full w-full object-cover transition-[filter] duration-700"
            style="filter: blur(0px)"
            width={640}
            height={800}
            loading="eager"
            decoding="async"
          />
        </div>
        <script is:inline>
          (function () {
            var img = document.getElementById("hero-img");
            if (!img) return;
            var hi = new window.Image();
            hi.onload = function () {
              img.src = hi.src;
            };
            hi.src = img.dataset.hires;
          })();
        </script>
        {/* Floating card */}
        <div
          class="absolute -bottom-4 -left-8 rounded-xl bg-white p-4 shadow-lg ring-1 ring-neutral-900/5"
        >
          <div class="flex items-center gap-3">
            <div
              class="flex h-10 w-10 items-center justify-center rounded-lg bg-green-50"
            >
              <svg
                class="h-5 w-5 text-green-600"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path></svg
              >
            </div>
            <div>
              <p class="text-xs font-semibold text-dark">
                Certified &amp; Insured
              </p>
              <p class="text-[11px] text-neutral-600">
                NDGAA &amp; IPG Members
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {
    /* ═══════════════════════════════════════════════════════
      SERVICES — Clean card grid
      ═══════════════════════════════════════════════════════ */
  }
  <section
    class="relative bg-white py-20 sm:py-28"
    aria-labelledby="services-heading"
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <span
          class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-primary-600"
        >
          <span class="h-px w-8 bg-primary-400" aria-hidden="true"></span>
          What We Offer
        </span>
        <h2
          id="services-heading"
          class="mt-4 font-display text-3xl font-bold tracking-tight text-dark sm:text-4xl"
        >
          Grooming services tailored to your pet
        </h2>
        <p class="mt-4 text-neutral-600 leading-relaxed">
          From a simple bath to a full spa experience, we customize every visit
          to your pet's breed, coat, and personality.
        </p>
      </div>

      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          [
            {
              title: "Full Groom",
              desc: "Complete haircut, bath, blow-dry, nail trim, ear cleaning, and finishing touches.",
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M7.848 8.25l1.536.887M7.848 8.25a3 3 0 11-5.196-3 3 3 0 015.196 3zm1.536.887a2.165 2.165 0 011.083 1.839c.005.56.01 1.121.02 1.681a.333.333 0 01-.104.262 19.412 19.412 0 01-3.233 2.477 14.902 14.902 0 01-6.65 2.604m12.5-9.863l-1.536.887m1.536-.887a3 3 0 115.196-3 3 3 0 01-5.196 3zm-1.536.887a2.165 2.165 0 00-1.083 1.839 24.08 24.08 0 01-.02 1.681.333.333 0 00.104.262 19.412 19.412 0 003.233 2.477 14.902 14.902 0 006.65 2.604" />`,
            },
            {
              title: "Bath & Brush",
              desc: "Luxurious deep cleansing bath, conditioning, professional blow-dry, and thorough brush-out.",
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />`,
            },
            {
              title: "Cat Grooming",
              desc: "Gentle, feline-specific grooming in a calm setting. Bath, brush, nail trim, and ear care.",
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z" />`,
            },
            {
              title: "Specialty Add-ons",
              desc: "Teeth brushing, de-shedding treatments, flea baths, paw balm, and creative styling.",
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />`,
            },
          ].map((service) => (
            <div class="group relative rounded-2xl border border-neutral-100 bg-neutral-50/50 p-6 transition-all duration-300 hover:border-primary-200 hover:bg-white hover:shadow-lg hover:shadow-primary-600/5">
              <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-primary-50 text-primary-600 transition-colors group-hover:bg-primary-600 group-hover:text-white">
                <svg
                  class="h-5 w-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  aria-hidden="true"
                  set:html={service.icon}
                />
              </div>
              <h3 class="mt-4 text-base font-semibold text-dark">
                {service.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-neutral-600">
                {service.desc}
              </p>
            </div>
          ))
        }
      </div>

      <div class="mt-12 text-center">
        <a
          href="/services"
          class="group inline-flex items-center gap-2 text-sm font-semibold text-primary-600 transition-colors hover:text-primary-500"
        >
          See all services &amp; pricing
          <svg
            class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2.5"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  {
    /* ═══════════════════════════════════════════════════════
      WHY CHOOSE US — Alternating feature blocks
      ═══════════════════════════════════════════════════════ */
  }
  <section
    class="relative overflow-hidden bg-primary-800 py-20 sm:py-28"
    aria-labelledby="why-heading"
  >
    {/* Subtle pattern */}
    <div
      class="absolute inset-0 opacity-[0.03]"
      style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 32px 32px;"
      aria-hidden="true"
    >
    </div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <span
          class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-primary-300"
        >
          <span class="h-px w-8 bg-primary-500" aria-hidden="true"></span>
          Why Pet Parents Choose Us
          <span class="h-px w-8 bg-primary-500" aria-hidden="true"></span>
        </span>
        <h2
          id="why-heading"
          class="mt-4 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl"
        >
          A grooming experience built on trust
        </h2>
      </div>

      <div class="mt-16 grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
        {
          [
            {
              title: "Certified Professionals",
              desc: "Nationally certified groomers (NDGAA & IPG) with years of hands-on experience across all breeds.",
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />`,
            },
            {
              title: "Gentle, Fear-Free Handling",
              desc: "We practice low-stress techniques, taking extra time with nervous or senior pets to build comfort.",
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />`,
            },
            {
              title: "Premium Products Only",
              desc: "Hypoallergenic, all-natural shampoos and conditioners. No harsh chemicals ever touch your pet.",
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />`,
            },
            {
              title: "Locally Owned Since " + business.founded,
              desc: `Not a franchise. We're part of the ${business.address.city} community and treat every pet like our own.`,
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />`,
            },
            {
              title: "Easy Online Booking",
              desc: "Book your preferred time in under a minute. Get reminders, and manage appointments from your phone.",
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />`,
            },
            {
              title: "Hundreds of 5-Star Reviews",
              desc: "Consistently rated the top groomer in the area. Read what real pet parents say about us.",
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />`,
            },
          ].map((item) => (
            <div class="flex gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-white/10 text-primary-200">
                <svg
                  class="h-5 w-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  aria-hidden="true"
                  set:html={item.icon}
                />
              </div>
              <div>
                <h3 class="font-semibold text-white">{item.title}</h3>
                <p class="mt-1.5 text-sm leading-relaxed text-primary-200">
                  {item.desc}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {
    /* ═══════════════════════════════════════════════════════
      TESTIMONIALS — Editorial quote cards
      ═══════════════════════════════════════════════════════ */
  }
  <section
    class="bg-neutral-50 py-20 sm:py-28"
    aria-labelledby="testimonials-heading"
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-center text-center">
        <span
          class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-primary-600"
        >
          <span class="h-px w-8 bg-primary-400" aria-hidden="true"></span>
          Testimonials
          <span class="h-px w-8 bg-primary-400" aria-hidden="true"></span>
        </span>
        <h2
          id="testimonials-heading"
          class="mt-4 font-display text-3xl font-bold tracking-tight text-dark sm:text-4xl"
        >
          Loved by pet parents
        </h2>
      </div>

      <div class="mt-14 grid gap-8 lg:grid-cols-3">
        {
          [
            {
              name: "Sarah M.",
              pet: "Golden Retriever owner",
              text: "My dog has never looked better! The staff was incredibly gentle and professional. The difference in quality compared to our last groomer is night and day. We'll definitely be back.",
              stars: 5,
            },
            {
              name: "James L.",
              pet: "Cat parent",
              text: "I was nervous about getting my cat groomed for the first time, but they made the whole experience calm and stress-free. The team genuinely understands cats. Highly recommend!",
              stars: 5,
            },
            {
              name: "Maria R.",
              pet: "Poodle mix owner",
              text: "Best grooming service in town, hands down. The attention to detail is incredible — from the hand-scissoring to the final bow. And the online booking makes everything so easy.",
              stars: 5,
            },
          ].map((review) => (
            <blockquote class="relative flex flex-col rounded-2xl bg-white p-8 shadow-sm ring-1 ring-neutral-900/5">
              {/* Quote mark */}
              <svg
                class="absolute right-6 top-6 h-10 w-10 text-primary-100"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11h4v10H0z" />
              </svg>
              {/* Stars */}
              <div
                class="flex gap-0.5 text-accent-400"
                role="img"
                aria-label={`${review.stars} out of 5 stars`}
              >
                {Array.from({ length: review.stars }).map(() => (
                  <svg
                    class="h-4 w-4 fill-current"
                    viewBox="0 0 20 20"
                    aria-hidden="true"
                  >
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <p class="mt-5 flex-1 text-[15px] leading-relaxed text-neutral-600">
                {review.text}
              </p>
              <footer class="mt-auto flex items-center gap-3 border-t border-neutral-100 pt-5">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary-50 font-display text-sm font-bold text-primary-600">
                  {review.name.charAt(0)}
                </div>
                <div>
                  <cite class="text-sm font-semibold not-italic text-dark">
                    {review.name}
                  </cite>
                  <p class="text-xs text-neutral-600">{review.pet}</p>
                </div>
              </footer>
            </blockquote>
          ))
        }
      </div>
    </div>
  </section>

  {
    /* ═══════════════════════════════════════════════════════
      CTA — Warm, inviting section
      ═══════════════════════════════════════════════════════ */
  }
  <section
    class="relative overflow-hidden bg-primary-600"
    aria-labelledby="cta-heading"
  >
    <div
      class="absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 24px 24px;"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute -right-20 -top-20 h-80 w-80 rounded-full bg-primary-500/50"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute -bottom-20 -left-20 h-60 w-60 rounded-full bg-primary-700/50"
      aria-hidden="true"
    >
    </div>

    <div
      class="relative mx-auto flex max-w-4xl flex-col items-center px-4 py-20 text-center sm:px-6 sm:py-24 lg:px-8"
    >
      <h2
        id="cta-heading"
        class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl"
      >
        Ready to pamper your pet?
      </h2>
      <p class="mt-4 max-w-xl text-lg text-primary-100">
        Book an appointment today and see why pet parents across {
          business.address.city
        } trust us with their furry family members.
      </p>
      <div class="mt-8 flex flex-col gap-4 sm:flex-row">
        <a
          href="/booking"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-white px-8 py-4 text-sm font-semibold text-primary-700 shadow-lg transition-all hover:bg-neutral-50 hover:shadow-xl active:scale-[0.97]"
        >
          Book Now
          <svg
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2.5"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
          </svg>
        </a>
        <a
          href={`tel:${business.phone.replace(/[^+\d]/g, "")}`}
          class="inline-flex items-center justify-center gap-2 rounded-lg border-2 border-white/30 px-8 py-4 text-sm font-semibold text-white transition-all hover:border-white/60 hover:bg-white/10"
        >
          <svg
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
            ></path>
          </svg>
          Call {business.phone}
        </a>
      </div>
    </div>
  </section>

  {
    /* ═══════════════════════════════════════════════════════
      FAQ — Clean accordion
      ═══════════════════════════════════════════════════════ */
  }
  <section class="bg-white py-20 sm:py-28" aria-labelledby="faq-heading">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <span
          class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-primary-600"
        >
          <span class="h-px w-8 bg-primary-400" aria-hidden="true"></span>
          FAQ
          <span class="h-px w-8 bg-primary-400" aria-hidden="true"></span>
        </span>
        <h2
          id="faq-heading"
          class="mt-4 font-display text-3xl font-bold tracking-tight text-dark sm:text-4xl"
        >
          Common questions
        </h2>
      </div>

      <div class="mt-12 space-y-3">
        {
          [
            {
              q: "How often should I have my dog groomed?",
              a: "Most dogs benefit from professional grooming every 4–6 weeks, though this varies by breed, coat type, and lifestyle. We're happy to recommend a personalized schedule during your first visit.",
            },
            {
              q: "Do I need to stay during the appointment?",
              a: "You're welcome to stay, but most pet parents prefer to drop off and pick up. We'll call or text you the moment your pet is ready!",
            },
            {
              q: "What if my pet is anxious about grooming?",
              a: "We specialize in gentle, fear-free handling techniques and maintain a calm environment. For especially anxious pets, we offer shorter introductory sessions to build trust gradually.",
            },
          ].map((item) => (
            <details class="group rounded-xl border border-neutral-200 bg-neutral-50/50 transition-colors open:bg-white open:shadow-sm">
              <summary class="flex cursor-pointer select-none items-center justify-between gap-4 px-6 py-5 text-left font-medium text-dark">
                <span>{item.q}</span>
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-neutral-300 text-neutral-400 transition-all group-open:border-primary-200 group-open:bg-primary-50 group-open:text-primary-600">
                  <svg
                    class="h-3.5 w-3.5 transition-transform group-open:rotate-180"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2.5"
                    stroke="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M19.5 8.25l-7.5 7.5-7.5-7.5"
                    />
                  </svg>
                </span>
              </summary>
              <div class="px-6 pb-5 text-sm leading-relaxed text-neutral-600">
                {item.a}
              </div>
            </details>
          ))
        }
      </div>

      <div class="mt-10 text-center">
        <a
          href="/faq"
          class="group inline-flex items-center gap-2 text-sm font-semibold text-primary-600 transition-colors hover:text-primary-500"
        >
          See all frequently asked questions
          <svg
            class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2.5"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

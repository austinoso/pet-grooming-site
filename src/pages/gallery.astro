---
import PageLayout from "../layouts/PageLayout.astro";
import GalleryGrid from "../components/gallery/GalleryGrid";
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";

const allGallery = await getCollection("gallery");
const galleryItems = await Promise.all(
  allGallery
    .sort((a, b) => a.data.order - b.data.order)
    .map(async (item) => {
      const optimized = await getImage({
        src: item.data.image,
        width: 800,
        height: 800,
        format: "webp",
        quality: 80,
      });
      return {
        src: optimized.src,
        alt: item.data.alt,
        title: item.data.title,
        category: item.data.category,
      };
    }),
);
---

<PageLayout
  title="Gallery"
  heading="Our Gallery"
  subheading="See the transformations! Browse photos of our happy, freshly groomed clients."
>
  <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
    <GalleryGrid items={galleryItems} client:load />
  </section>

  {/* CTA */}
  <section
    class="relative overflow-hidden bg-primary-600 py-16"
    aria-labelledby="gallery-cta"
  >
    <div
      class="absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 24px 24px;"
      aria-hidden="true"
    >
    </div>
    <div class="relative mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 id="gallery-cta" class="font-display text-2xl font-bold text-white">
        Want your pet featured here?
      </h2>
      <p class="mt-3 text-primary-100">
        Book a grooming session and your pet could be our next star!
      </p>
      <a
        href="/booking"
        class="mt-6 inline-flex items-center justify-center gap-2 rounded-lg bg-white px-8 py-3.5 text-sm font-semibold text-primary-700 shadow-lg transition-all hover:bg-neutral-50 active:scale-[0.97]"
      >
        Book Now
        <svg
          class="h-3.5 w-3.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
        </svg>
      </a>
    </div>
  </section>
</PageLayout>

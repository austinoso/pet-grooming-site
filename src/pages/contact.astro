---
import PageLayout from "../layouts/PageLayout.astro";
import ContactForm from "../components/contact/ContactForm";
const business = Astro.locals.tenant;
---

<PageLayout
  title="Contact Us"
  heading="Get in Touch"
  subheading="We'd love to hear from you. Reach out with any questions or to schedule an appointment."
>
  <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-5">
      {/* Contact Form */}
      <div class="lg:col-span-3">
        <div
          class="rounded-2xl border border-neutral-100 bg-white p-6 shadow-sm ring-1 ring-neutral-900/5 sm:p-8"
        >
          <h2 class="font-display text-xl font-bold text-dark">
            Send Us a Message
          </h2>
          <p class="mt-1 text-sm text-neutral-500">
            We'll get back to you within 24 hours.
          </p>
          <ContactForm client:load />
        </div>
      </div>

      {/* Contact Info Sidebar */}
      <div class="lg:col-span-2 space-y-8">
        {/* Address */}
        <div class="rounded-2xl border border-neutral-100 bg-neutral-50/50 p-6">
          <div
            class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-50 text-primary-600"
          >
            <svg
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
              ></path>
            </svg>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-dark">Visit Us</h3>
          <address
            class="mt-2 text-sm not-italic leading-relaxed text-neutral-600"
          >
            {business.address.street}<br />
            {business.address.city}, {business.address.stateAbbr}
            {business.address.zip}
          </address>
        </div>

        {/* Phone */}
        <div class="rounded-2xl border border-neutral-100 bg-neutral-50/50 p-6">
          <div
            class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-50 text-primary-600"
          >
            <svg
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
              ></path>
            </svg>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-dark">Call Us</h3>
          <a
            href={`tel:${business.phone.replace(/[^+\d]/g, "")}`}
            class="mt-2 inline-block text-lg font-semibold text-primary-600 no-underline hover:text-primary-500"
          >
            {business.phone}
          </a>
        </div>

        {/* Email */}
        <div class="rounded-2xl border border-neutral-100 bg-neutral-50/50 p-6">
          <div
            class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-50 text-primary-600"
          >
            <svg
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
              ></path>
            </svg>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-dark">Email Us</h3>
          <a
            href={`mailto:${business.email}`}
            class="mt-2 inline-block text-sm text-primary-600 no-underline hover:text-primary-500"
          >
            {business.email}
          </a>
        </div>

        {/* Hours */}
        <div class="rounded-2xl border border-neutral-100 bg-neutral-50/50 p-6">
          <div
            class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-50 text-primary-600"
          >
            <svg
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-dark">Business Hours</h3>
          <dl class="mt-3 space-y-1 text-sm text-neutral-600">
            {
              business.hours.map((h) => (
                <div class="flex justify-between gap-4">
                  <dt class="text-neutral-500">{h.day}</dt>
                  <dd class={h.closed ? "text-neutral-400" : ""}>
                    {h.closed ? "Closed" : `${h.open} – ${h.close}`}
                  </dd>
                </div>
              ))
            }
          </dl>
        </div>
      </div>
    </div>
  </section>

  {/* Map Embed Placeholder */}
  <section class="bg-neutral-50 py-12" aria-labelledby="map-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 id="map-heading" class="sr-only">Our Location</h2>
      <div
        class="overflow-hidden rounded-2xl border border-neutral-200 bg-neutral-200 shadow-sm"
      >
        <div class="flex h-80 items-center justify-center">
          <div class="text-center">
            <svg
              class="mx-auto h-12 w-12 text-neutral-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
              ></path>
            </svg>
            <p class="mt-3 text-sm text-neutral-500">
              Map embed placeholder — {business.address.street}, {
                business.address.city
              }, {business.address.stateAbbr}
              {business.address.zip}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

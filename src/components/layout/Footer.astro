---
/**
 * Footer — Editorial layout with brand, navigation, contact, hours.
 * Astro component (no client JS needed).
 */
import { footerNav } from "../../config/navigation";
const business = Astro.locals.tenant;
---

<footer class="bg-dark text-neutral-200" role="contentinfo">
  <div class="mx-auto max-w-7xl px-4 pb-12 pt-16 sm:px-6 lg:px-8">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      {/* Brand */}
      <div class="lg:pr-8">
        <a href="/" class="group inline-flex items-start gap-2.5 no-underline">
          <div
            class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-primary-600"
          >
            <svg
              class="h-4.5 w-4.5 text-white"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <circle cx="7" cy="5" r="2.5"></circle>
              <circle cx="17" cy="5" r="2.5"></circle>
              <circle cx="4" cy="12" r="2.5"></circle>
              <circle cx="20" cy="12" r="2.5"></circle>
              <ellipse cx="12" cy="17" rx="5" ry="4"></ellipse>
            </svg>
          </div>
          <span class="font-display text-xl font-bold text-white"
            >{business.name}</span
          >
        </a>
        <p class="mt-4 text-sm leading-relaxed text-neutral-300">
          {business.tagline}. Proudly serving the {business.address.city} area since
          {business.founded}.
        </p>
        {/* Social */}
        <div class="mt-6 flex gap-3">
          {
            business.social.map((s) => (
              <a
                href={s.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/10 text-neutral-300 transition-colors hover:bg-primary-600 hover:text-white"
                aria-label={s.label}
              >
                {s.platform === "Facebook" && (
                  <svg
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="h-4 w-4"
                    aria-hidden="true"
                  >
                    <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" />
                  </svg>
                )}
                {s.platform === "Instagram" && (
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    class="h-4 w-4"
                    aria-hidden="true"
                  >
                    <rect x="2" y="2" width="20" height="20" rx="5.5" />
                    <circle cx="12" cy="12" r="4" />
                    <circle
                      cx="17.5"
                      cy="6.5"
                      r="0.5"
                      fill="currentColor"
                      stroke="none"
                    />
                  </svg>
                )}
                {s.platform !== "Facebook" && s.platform !== "Instagram" && (
                  <svg
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="h-4 w-4"
                    aria-hidden="true"
                  >
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                  </svg>
                )}
              </a>
            ))
          }
        </div>
      </div>

      {/* Quick Links */}
      <div>
        <h3
          class="text-xs font-semibold uppercase tracking-[0.15em] text-neutral-400"
        >
          Quick Links
        </h3>
        <nav class="mt-5 flex flex-col gap-2.5" aria-label="Footer navigation">
          {
            footerNav.map((item) => (
              <a
                href={item.href}
                class="text-sm text-neutral-300 no-underline transition-colors hover:text-white"
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>

      {/* Contact Info */}
      <div>
        <h3
          class="text-xs font-semibold uppercase tracking-[0.15em] text-neutral-400"
        >
          Contact
        </h3>
        <address
          class="mt-5 flex flex-col gap-3 text-sm not-italic text-neutral-300"
        >
          <div class="flex items-start gap-2.5">
            <svg
              class="mt-0.5 h-4 w-4 shrink-0 text-primary-500"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
              ></path>
            </svg>
            <span
              >{business.address.street}<br />{business.address.city}, {
                business.address.stateAbbr
              }
              {business.address.zip}</span
            >
          </div>
          <div class="flex items-center gap-2.5">
            <svg
              class="h-4 w-4 shrink-0 text-primary-500"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
              ></path>
            </svg>
            <a
              href={`tel:${business.phone.replace(/[^+\d]/g, "")}`}
              class="text-neutral-300 no-underline transition-colors hover:text-white"
              >{business.phone}</a
            >
          </div>
          <div class="flex items-center gap-2.5">
            <svg
              class="h-4 w-4 shrink-0 text-primary-500"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
              ></path>
            </svg>
            <a
              href={`mailto:${business.email}`}
              class="text-neutral-300 no-underline transition-colors hover:text-white"
              >{business.email}</a
            >
          </div>
        </address>
      </div>

      {/* Hours */}
      <div>
        <h3
          class="text-xs font-semibold uppercase tracking-[0.15em] text-neutral-400"
        >
          Hours
        </h3>
        <dl class="mt-5 flex flex-col gap-1.5 text-sm text-neutral-300">
          {
            business.hours.map((h) => (
              <div class="flex justify-between gap-4">
                <dt class="text-neutral-400">{h.day}</dt>
                <dd class={h.closed ? "text-neutral-500" : "text-neutral-200"}>
                  {h.closed ? "Closed" : `${h.open} – ${h.close}`}
                </dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>

    {/* Divider + copyright */}
    <div class="mt-12 border-t border-white/10 pt-8">
      <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
        <p class="text-xs text-neutral-400">
          &copy; {new Date().getFullYear()}
          {business.name}. All rights reserved.
        </p>
        <div class="flex gap-6 text-xs text-neutral-400">
          <a
            href="/policies"
            class="no-underline transition-colors hover:text-neutral-300"
            >Privacy Policy</a
          >
          <a
            href="/policies"
            class="no-underline transition-colors hover:text-neutral-300"
            >Terms of Service</a
          >
        </div>
      </div>
    </div>
  </div>
</footer>

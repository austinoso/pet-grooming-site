---
/**
 * SEOHead — Renders all meta tags, Open Graph, Twitter Cards, and JSON-LD.
 * Used inside BaseLayout's <head>.
 */
import { buildTitle, getDefaultSEO } from "../../config/seo";
import type { PageSEO } from "../../config/seo";

interface Props extends PageSEO {
  jsonLd?: Record<string, unknown>;
}

const tenant = Astro.locals.tenant;
const defaults = getDefaultSEO(tenant);
const siteUrl = tenant.siteUrl;

const {
  title: rawTitle,
  description = defaults.description,
  canonical,
  ogImage = defaults.ogImage,
  ogType = defaults.ogType,
  noindex = false,
  jsonLd,
} = Astro.props;

const title = buildTitle(tenant, rawTitle);
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;

// Default LocalBusiness JSON-LD (can be overridden per page via jsonLd prop)
const defaultJsonLd = {
  "@context": "https://schema.org",
  "@type": "PetGrooming",
  name: tenant.name,
  description: tenant.description,
  url: siteUrl,
  telephone: tenant.phone,
  email: tenant.email,
  address: {
    "@type": "PostalAddress",
    streetAddress: tenant.address.street,
    addressLocality: tenant.address.city,
    addressRegion: tenant.address.stateAbbr,
    postalCode: tenant.address.zip,
    addressCountry: tenant.address.country,
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: tenant.coordinates.lat,
    longitude: tenant.coordinates.lng,
  },
  areaServed: tenant.serviceArea.map((area) => ({
    "@type": "City",
    name: area,
  })),
  openingHoursSpecification: tenant.hours
    .filter((h) => !h.closed)
    .map((h) => ({
      "@type": "OpeningHoursSpecification",
      dayOfWeek: h.day,
      opens: h.open,
      closes: h.close,
    })),
};

const structuredData = jsonLd ?? defaultJsonLd;
---

<!-- Primary Meta -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={description} />
<meta property="og:site_name" content={tenant.name} />
<meta property="og:locale" content="en_US" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- Geo Meta (Local SEO) -->
<meta
  name="geo.region"
  content={`${tenant.address.country}-${tenant.address.stateAbbr}`}
/>
<meta name="geo.placename" content={tenant.address.city} />
<meta
  name="geo.position"
  content={`${tenant.coordinates.lat};${tenant.coordinates.lng}`}
/>
<meta
  name="ICBM"
  content={`${tenant.coordinates.lat}, ${tenant.coordinates.lng}`}
/>

<!-- JSON-LD Structured Data -->
<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify(structuredData)}
/>

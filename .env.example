# ─────────────────────────────────────────────────────────────────────────────
# Tenant Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env for local dev, OR set these as environment variables
# in your hosting dashboard (Netlify / Vercel) for each subdomain deployment.
#
# PUBLIC_TENANT   — must match a key in src/config/active-tenant.ts registry
# PUBLIC_SITE_URL — the full URL of this deployment (used for SEO / sitemap)
# ─────────────────────────────────────────────────────────────────────────────

PUBLIC_TENANT=your-client-slug
PUBLIC_SITE_URL=https://clientname.yourdomain.com
